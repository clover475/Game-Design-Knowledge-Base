# Local Obsidian state
.obsidian/workspace*.json
.obsidian/cache/
.obsidian/plugins/*/data.json

# Large or private source materials
01_raw_sources/**/*.pdf
01_raw_sources/**/*.epub
01_raw_sources/**/*.mobi
01_raw_sources/**/*.zip
01_raw_sources/**/*.mp4
01_raw_sources/**/*.mov
01_raw_sources/**/*.psd
01_raw_sources/**/*.blend

# Local clones and generated exports
01_raw_sources/github_repos/*/
01_raw_sources/open_source_games/*/
outputs/
work/

# Local cloned third-party repositories for the Obsidian vault.
# Keep their metadata in GameDesign_KB/02_indexes/repo_index.md instead.
GameDesign_KB/01_open_resources/github_repos/*/
GameDesign_KB/01_open_resources/gdd_examples/*/

# User-provided book files are local-first; index them instead of committing by default.
GameDesign_KB/00_books/*
!GameDesign_KB/00_books/.gitkeep
GameDesign_KB/01_open_resources/open_books/*
!GameDesign_KB/01_open_resources/open_books/.gitkeep

# OS/editor noise
.DS_Store
Thumbs.db
*.tmp
*.log
